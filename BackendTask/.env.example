DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskmanager"
JWT_SECRET="change-me"
PORT=3001

# Para pruebas locales: true salta el codigo de seguridad y devuelve el token en /auth/login.
# Para volver al flujo normal de codigo por correo, usar false o borrar la variable.
SKIP_SECURITY_CODE=false

# Opcional: si no estan configurados, el backend devuelve el codigo en la respuesta para local.
RESEND_API_KEY=
EMAIL_FROM=
